---
type Props = {
  title: string;
  description: string;
  tags?: string[];
  href: string;
};

const { title, description, tags = [], href } = Astro.props;
---

<article class="card">
  <h2><a href={href}>{title}</a></h2>
  <p>{description}</p>
  {tags.length > 0 && (
    <div class="tag-row" aria-label="Tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>
