---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { withBase } from '../paths';

const avatarUrl = withBase(site.avatar);
---

<BaseLayout title={site.name} description={site.tagline}>
  <section class="hero">
    <img class="avatar" src={avatarUrl} alt={`${site.name} avatar`} width="192" height="192" fetchpriority="high" />
    <h1 class="hero-title">{site.name}</h1>
    <p class="hero-copy">
      {site.tagline}
      <br />
      Currently exploring <a class="blue-link" href={withBase('/projects')}>personal products</a> and
      <a class="blue-link" href={withBase('/writing')}>clear technical writing</a>.
    </p>
    <div class="badge-row" aria-label="Highlights">
      {site.badges.map((badge) => <span class="badge">{badge}</span>)}
    </div>
    <div class="cta-row">
      <a class="button primary" href={withBase('/about')}>About Me</a>
      <a class="button" href={withBase('/resume')}>View Resume</a>
    </div>
  </section>
</BaseLayout>
