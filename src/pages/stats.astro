---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title="Stats" description={`${site.name} personal stats`}>
  <section class="page-section container centered">
    <h1 class="page-title">Stats</h1>
    <p class="lead">一个轻量快照：项目、写作、测试和交叉背景。</p>
    <div class="stat-grid">
      <div class="stat"><strong>4</strong><span>Selected Projects</span></div>
      <div class="stat"><strong>30</strong><span>CSDN Articles</span></div>
      <div class="stat"><strong>110+</strong><span>orderToZhu Tests</span></div>
      <div class="stat"><strong>2</strong><span>Study Fields</span></div>
    </div>
  </section>
</BaseLayout>
