---
import BaseLayout from '../layouts/BaseLayout.astro';
import { posts, site } from '../data/site';
import { withBase } from '../paths';
import { formatDate } from '../utils';
---

<BaseLayout title="Writing" description={`${site.name} writing archive`}>
  <section class="page-section container">
    <h1 class="page-title">Writing</h1>
    <p class="lead" style="margin-left:0">
      我曾持续撰写 CSDN 原创技术文章。这里先放公开写作方向和待整理的项目复盘，后续会逐步补充完整文章链接。
    </p>
    <div class="resume-list">
      {posts.map((post) => (
        <article class="resume-card">
          <p class="resume-meta">{formatDate(post.date)}</p>
          <h2><a href={withBase(post.href)}>{post.title}</a></h2>
          <p>{post.summary}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
